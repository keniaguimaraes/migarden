<div class="page-header">
  <div>
    <h1 class="page-header__title">Configurações</h1>
    <p class="page-header__subtitle">Atualize seu perfil e as credenciais do WhatsApp.</p>
  </div>
</div>

<%= form_with model: @user, url: settings_path, method: :patch, local: true, class: "form" do |f| %>
  <% if @user.errors.any? %>
    <div class="form__errors">
      <strong>Não foi possível salvar:</strong>
      <ul>
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <h2 class="settings__section-title">Perfil</h2>
    <div class="form__grid">
      <div class="form__field">
        <%= f.label :name, "Nome", class: "form__label" %>
        <%= f.text_field :name, required: true, class: "form__input" %>
      </div>

      <div class="form__field">
        <%= f.label :email, "E-mail", class: "form__label" %>
        <%= f.email_field :email, required: true, class: "form__input" %>
      </div>
    </div>
  </div>

  <div class="card">
    <h2 class="settings__section-title">WhatsApp (CallMeBot)</h2>
    <p class="settings__hint">
      Receba lembretes diários no seu WhatsApp. Obtenha sua API key enviando
      <code>/start</code> para o bot do CallMeBot
      (<a href="https://www.callmebot.com/blog/free-api-whatsapp-messages/" target="_blank" rel="noopener">instruções</a>).
    </p>
    <div class="form__grid">
      <div class="form__field">
        <%= f.label :callmebot_phone, "Telefone (com código do país)", class: "form__label" %>
        <%= f.telephone_field :callmebot_phone, class: "form__input", placeholder: "+5511999990000" %>
      </div>

      <div class="form__field">
        <%= f.label :callmebot_api_key, "API key", class: "form__label" %>
        <%= f.text_field :callmebot_api_key, class: "form__input", placeholder: "Sua chave do CallMeBot" %>
      </div>
    </div>

    <% if @user.callmebot_phone.present? && @user.callmebot_api_key.present? %>
      <p class="settings__status settings__status--ok">
        ✓ Notificações WhatsApp configuradas para <strong><%= @user.callmebot_phone %></strong>.
      </p>
      <%= button_to "📱 Enviar mensagem de teste",
            test_whatsapp_settings_path,
            method: :post,
            class: "btn btn--primary btn--sm",
            form: { data: { turbo_frame: "_top" } } %>
    <% else %>
      <p class="settings__status settings__status--warn">
        ⚠ Você ainda não receberá lembretes por WhatsApp até preencher ambos os campos.
      </p>
    <% end %>
  </div>

  <div class="card">
    <h2 class="settings__section-title">Alterar senha</h2>
    <p class="settings__hint">Deixe em branco para manter a senha atual.</p>
    <div class="form__grid">
      <div class="form__field">
        <%= f.label :password, "Nova senha", class: "form__label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form__input" %>
      </div>

      <div class="form__field">
        <%= f.label :password_confirmation, "Confirmação", class: "form__label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form__input" %>
      </div>
    </div>
  </div>

  <div class="form__actions">
    <%= f.submit "Salvar configurações", class: "btn btn--primary" %>
    <%= link_to "Cancelar", root_path, class: "btn btn--ghost" %>
  </div>
<% end %>
