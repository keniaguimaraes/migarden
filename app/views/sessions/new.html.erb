<div class="auth-card">
  <div class="auth-card__brand">🌿 migarden</div>
  <h1 class="auth-card__title">Entrar na sua conta</h1>
  <p class="auth-card__subtitle">Acompanhe os cuidados do seu jardim.</p>

  <%= form_with url: session_path, local: true, class: "form" do |f| %>
    <div class="form__field">
      <%= f.label :email, "E-mail", class: "form__label" %>
      <%= f.email_field :email, required: true, autofocus: true, class: "form__input" %>
    </div>

    <div class="form__field">
      <%= f.label :password, "Senha", class: "form__label" %>
      <%= f.password_field :password, required: true, class: "form__input" %>
    </div>

    <%= f.submit "Entrar", class: "btn btn--primary btn--block" %>
  <% end %>

  <p class="auth-card__footer">
    Ainda não tem conta? <%= link_to "Criar conta", new_user_path, class: "link" %>
  </p>
</div>
