<div class="page-header">
  <div>
    <h1 class="page-header__title">Alertas</h1>
    <p class="page-header__subtitle">Plantas que precisam de cuidado hoje.</p>
  </div>
  <%= link_to "Minhas Plantas", plants_path, class: "btn btn--ghost" %>
</div>

<section class="summary-grid">
  <div class="card summary-card">
    <div class="summary-card__icon summary-card__icon--water">💧</div>
    <div class="summary-card__label">Precisam de rega</div>
    <div class="summary-card__value"><%= @counts[:watering] %></div>
  </div>
  <div class="card summary-card">
    <div class="summary-card__icon summary-card__icon--fert">🧪</div>
    <div class="summary-card__label">Precisam de fertilização</div>
    <div class="summary-card__value"><%= @counts[:fertilization] %></div>
  </div>
  <div class="card summary-card">
    <div class="summary-card__icon summary-card__icon--pest">🐛</div>
    <div class="summary-card__label">Precisam de controle de pragas</div>
    <div class="summary-card__value"><%= @counts[:pest_control] %></div>
  </div>
</section>

<section class="dashboard__section">
  <h2 class="dashboard__section-title">Plantas pendentes</h2>
  <% if @pending_plants.any? %>
    <div class="plant-grid">
      <% @pending_plants.each do |plant| %>
        <%= render "plants/plant_card", plant: plant %>
      <% end %>
    </div>
  <% else %>
    <div class="card empty-state-card">
      <div class="empty-state__icon">✨</div>
      <h2 class="empty-state__title">Tudo em dia!</h2>
      <p class="empty-state__text">Nenhuma planta precisa de cuidado agora. Aproveite seu jardim.</p>
      <%= link_to "Ver todas as plantas", plants_path, class: "btn btn--primary" %>
    </div>
  <% end %>
</section>
