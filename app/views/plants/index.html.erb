<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  <% @plants.each do |plant| %>
    <div class="plant-card glass rounded-3xl p-6 relative overflow-hidden">
      <% if plant.image.attached? %>
        <div class="w-full h-48 mb-4 rounded-2xl overflow-hidden">
          <%= image_tag plant.image, class: "w-full h-full object-cover" %>
        </div>
      <% else %>
        <div class="w-full h-48 mb-4 bg-[#4A6D5B] rounded-2xl flex items-center justify-center text-4xl">
          🌿
        </div>
      <% end %>

      <div class="flex justify-between items-start mb-4">
        <div>
          <h3 class="text-xl font-semibold text-white"><%= plant.nickname || plant.name %></h3>
          <p class="text-sm text-gray-400"><%= plant.species %></p>
        </div>
        <div class="text-right">
          <span class="text-xs uppercase tracking-widest text-gray-400">Status</span>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-[#C5FF42] neon-glow"></div>
            <span class="text-sm font-medium text-white">Saudável</span>
          </div>
        </div>
      </div>

      <div class="flex gap-3 mt-6">
        <%= link_to plant_path(plant), class: "flex-1 text-center py-2 px-4 rounded-xl bg-white/10 hover:bg-white/20 transition-colors text-sm border border-white/10 text-white" do %>
          Detalhes
        <% end %>
      </div>
    </div>
  <% end %>
</div>
