<div class="page-header">
  <div>
    <h1 class="page-header__title">Minhas plantas</h1>
    <p id="plants_count" class="page-header__subtitle"><%= pluralize(@plants.count, "planta cadastrada", "plantas cadastradas") %> no seu jardim.</p>
  </div>
  <%= link_to "Nova planta",
        new_plant_path,
        data: { turbo_frame: "plant_modal" },
        class: "btn btn--primary" %>
</div>

<% if @plants.any? %>
  <div class="plant-table" id="plants_table">
    <table>
      <thead>
        <tr>
          <th>Foto</th>
          <th>Nome</th>
          <th>Tipo</th>
          <th>Sol</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <%= render partial: "plant_row", collection: @plants, as: :plant %>
      </tbody>
    </table>
  </div>

  <div class="plant-table plant-table--mobile-cards" id="plants_mobile_cards">
    <%= render partial: "plants/plant_card", collection: @plants, as: :plant %>
  </div>
<% else %>
  <div class="card empty-state-card" id="plants_empty">
    <div class="empty-state__icon">🌱</div>
    <h2 class="empty-state__title">Nenhuma planta ainda</h2>
    <p class="empty-state__text">Comece cadastrando sua primeira planta para receber lembretes.</p>
    <%= link_to "Cadastrar planta",
          new_plant_path,
          data: { turbo_frame: "plant_modal" },
          class: "btn btn--primary" %>
  </div>
<% end %>
