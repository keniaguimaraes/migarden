<div class="glass rounded-3xl p-8 max-w-4xl mx-auto mt-12 text-white">
  <div class="flex justify-between items-center mb-8">
    <div class="flex items-center gap-4">
      <%= link_to "← Voltar ao Jardim", plants_path, class: "text-gray-400 hover:text-white transition-colors text-sm" %>
    </div>
    <div class="text-right">
      <span class="text-xs uppercase tracking-widest text-gray-400">Espécie</span>
      <p class="text-lg font-medium"><%= @plant.species %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <div class="relative">
      <% if @plant.image.attached? %>
        <%= image_tag @plant.image, class: "w-full rounded-3xl shadow-2xl border-4 border-white/10 object-cover h-80" %>
      <% else %>
        <div class="w-full h-80 bg-moss-green rounded-3xl flex items-center justify-center text-6xl">🌿</div>
      <% end %>
      <div class="absolute -bottom-6 -right-6 glass rounded-full p-6 text-center shadow-xl border border-white/20">
        <span class="block text-xs uppercase text-gray-400">Apelido</span>
        <span class="text-xl font-bold"><%= @plant.nickname || @plant.name %></span>
      </div>
    </div>

    <div>
      <h1 class="font-display text-5xl mb-6"><%= @plant.name %></h1>

      <div class="space-y-6">
        <% @care_parameters.each do |param| %>
          <div class="glass rounded-2xl p-4 flex justify-between items-center border border-white/5">
            <div class="flex items-center gap-3">
              <span class="text-2xl">
                <%= param.action_type == 'watering' ? '💧' : (param.action_type == 'fertilization' ? '🧪' : '🐛') %>
              </span>
              <div>
                <p class="text-sm font-semibold capitalize"><%= param.action_type.humanize %></p>
                <p class="text-xs text-gray-400">A cada <%= param.interval_days %> dias</p>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <%# Integração com a lógica do CareCalculatorService %>
              <% if CareCalculatorService.due_today(param) %>
                <div class="flex items-center gap-2 text-[#C5FF42] animate-pulse">
                  <div class="w-2 h-2 rounded-full bg-[#C5FF42] neon-glow"></div>
                  <span class="text-xs font-bold uppercase">Vencendo</span>
                </div>
              <% else %>
                <span class="text-xs text-gray-500">No prazo</span>
              <% end %>

              <%= button_to "Remover", plant_care_parameter_path(@plant, param), method: :delete, data: { confirm: "Tem certeza?" }, class: "text-xs text-red-400 hover:text-red-300" %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-8">
        <%= link_to "Adicionar Parâmetro de Cuidado", new_plant_care_parameter_path(@plant), class: "bg-[#C5FF42] text-[#0B241A] px-4 py-2 rounded-full font-semibold hover:bg-white transition-colors" %>
      </div>

      <div class="mt-12">
        <%= form_with(model: CareLog.new, local: false, class: "flex flex-col gap-4") do |f| %>
          <%= f.hidden_field :plant_id, value: @plant.id %>
          <% @care_parameters.each do |param| %>
            <%= f.hidden_field :care_parameter_id, value: param.id %>
          <% end %>

          <div class="flex gap-3">
            <button type="submit" class="flex-1 bg-[#C5FF42] text-[#0B241A] py-4 rounded-2xl font-bold hover:bg-white transition-all transform hover:scale-105 shadow-lg">
              Marcar Cuidado como Concluído ✨
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-16">
    <h3 class="font-display text-2xl mb-6">Histórico de Cuidados</h3>
    <div class="space-y-4">
      <% @plant.care_logs.order(performed_at: :desc).each do |log| %>
        <div class="flex justify-between items-center p-4 rounded-2xl bg-white/5 border border-white/5">
          <div class="flex items-center gap-4">
            <span class="text-xl"><%= log.care_parameter.action_type == 'watering' ? '💧' : '🛠️' %></span>
            <div>
              <p class="text-sm font-medium"><%= log.care_parameter.action_type.humanize %></p>
              <p class="text-xs text-gray-400"><%= log.performed_at.strftime("%d/%m/%Y") %></p>
            </div>
          </div>
          <p class="text-sm text-gray-400 italic"><%= log.observation %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
