<div class="glass rounded-3xl p-8 max-w-4xl mx-auto mt-12 text-white">
  <div class="flex justify-between items-center mb-8">
    <div class="flex items-center gap-4">
      <%= link_to "← Voltar para #{@plant.name}", plant_path(@plant), class: "text-gray-400 hover:text-white transition-colors text-sm" %>
    </div>
    <div>
      <%= link_to "Adicionar Parâmetro", new_plant_care_parameter_path(@plant), class: "bg-[#C5FF42] text-[#0B241A] px-4 py-2 rounded-full font-semibold hover:bg-white transition-colors" %>
    </div>
  </div>

  <h1 class="font-display text-3xl mb-8">Parâmetros de Cuidado: <%= @plant.name %></h1>

  <div class="space-y-4">
    <% if @care_parameters.any? %>
      <% @care_parameters.each do |param| %>
        <div class="glass rounded-2xl p-4 flex justify-between items-center border border-white/5">
          <div class="flex items-center gap-3">
            <span class="text-2xl">
              <%= param.action_type == 'watering' ? '💧' : (param.action_type == 'fertilization' ? '🧪' : '🐛') %>
            </span>
            <div>
              <p class="text-sm font-semibold capitalize"><%= param.action_type.humanize %></p>
              <p class="text-xs text-gray-400">A cada <%= param.interval_days %> dias</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <% if CareCalculatorService.due_today(param) %>
              <div class="flex items-center gap-2 text-[#C5FF42] animate-pulse">
                <div class="w-2 h-2 rounded-full bg-[#C5FF42] neon-glow"></div>
                <span class="text-xs font-bold uppercase">Vencendo</span>
              </div>
            <% else %>
              <span class="text-xs text-gray-500">No prazo</span>
            <% end %>

            <%= button_to "Remover", plant_care_parameter_path(@plant, param), method: :delete, data: { confirm: "Tem certeza?" }, class: "text-xs text-red-400 hover:text-red-300" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-400 text-center py-8">Nenhum parâmetro de cuidado cadastrado ainda.</p>
    <% end %>
  </div>
</div>
