<div class="glass rounded-3xl p-8 max-w-md mx-auto mt-12 text-white">
  <div class="flex justify-between items-center mb-8">
    <div class="flex items-center gap-4">
      <%= link_to "← Voltar para #{@plant.name}", plant_path(@plant), class: "text-gray-400 hover:text-white transition-colors text-sm" %>
    </div>
  </div>

  <h2 class="font-display text-3xl mb-6 text-center">Novo Parâmetro de Cuidado</h2>

  <%= form_with(model: [@plant, @care_parameter], local: true, class: "space-y-6") do |f| %>
    <div>
      <%= f.label :action_type, "Tipo de Cuidado", class: "block text-xs uppercase tracking-widest text-gray-400 mb-2" %>
      <%= f.select :action_type, options_for_select([["💧 Rega", "watering"], ["🧪 Fertilização", "fertilization"], ["🐛 Inseticida", "insecticide"]]), {}, class: "w-full bg-white/10 border border-white/10 rounded-xl p-3 text-white focus:ring-2 focus:ring-[#C5FF42] outline-none" %>
    </div>
    <div>
      <%= f.label :interval_days, "Intervalo (dias)", class: "block text-xs uppercase tracking-widest text-gray-400 mb-2" %>
      <%= f.number_field :interval_days, min: 1, value: 7, class: "w-full bg-white/10 border border-white/10 rounded-xl p-3 text-white placeholder-gray-500 focus:ring-2 focus:ring-[#C5FF42] outline-none" %>
    </div>
    <%= f.submit "Adicionar", class: "w-full bg-[#C5FF42] text-[#0B241A] py-4 rounded-2xl font-bold hover:bg-white transition-all shadow-lg" %>
  <% end %>
</div>
